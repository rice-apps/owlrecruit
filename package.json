{
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern node_modules",
    "format": "prettier --write '**/*.{js,ts,tsx,css,html}'",
    "update-types:remote": "npx supabase gen types typescript --linked > types/supabase.ts",
    "update-types:local": "npx supabase gen types typescript --local > types/supabase.ts",
    "seed:local": "psql ${DATABASE_URL:-postgresql://postgres:postgres@localhost:54322/postgres} -f supabase/seed/00-reset.sql -f supabase/seed/01-users.sql -f supabase/seed/02-orgs.sql -f supabase/seed/03-org-members.sql -f supabase/seed/04-openings.sql -f supabase/seed/05-applications.sql -f supabase/seed/06-reviews.sql -f supabase/seed/07-interviews.sql",
    "db:reset": "supabase db reset",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "playwright test"
  },
  "dependencies": {
    "@mantine/core": "^9.1.0",
    "@mantine/dates": "^9.1.0",
    "@mantine/dropzone": "^9.1.0",
    "@mantine/form": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "@mantine/notifications": "^9.1.0",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "@untitled-ui/icons-react": "^0.1.4",
    "dayjs": "^1.11.20",
    "next": "^16.2.4",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "supabase": "^2.74.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.1.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.7.4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
